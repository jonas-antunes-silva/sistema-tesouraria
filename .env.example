# =============================================================================
# PostgreSQL
# =============================================================================

# Nome do banco de dados
POSTGRES_DB=tesouraria

# Usuário do banco de dados
POSTGRES_USER=tesouraria

# Senha do banco de dados (obrigatório — defina antes de iniciar os containers)
POSTGRES_PASSWORD=

# URL de conexão completa usada pela aplicação Nuxt
# Substitua SENHA pelo valor definido em POSTGRES_PASSWORD
DATABASE_URL=postgresql://tesouraria:SENHA@postgres:5432/tesouraria

# =============================================================================
# JWT (JSON Web Token)
# =============================================================================

# Chave secreta para assinar tokens JWT HS256
# Obrigatório — mínimo de 32 caracteres; use um valor aleatório forte em produção
JWT_SECRET=

# Tempo de expiração dos tokens JWT (ex: 8h, 1d, 30m)
JWT_EXPIRES_IN=8h

# =============================================================================
# SISGRU — Webservice do Tesouro Nacional
# =============================================================================

# URL base do webservice SISGRU
SISGRU_URL_BASE=https://webservice.sisgru.tesouro.gov.br/sisgru/services/v1

# Identificador do emissor (issuer) no JWT RS256 enviado ao SISGRU
SISGRU_ISSUER=tesouraria

# Caminho interno do container para a chave privada RSA usada na autenticação RS256
# Monte o arquivo via Docker secret ou volume em produção
SISGRU_PRIVATE_KEY_PATH=/run/secrets/sisgru.pem

# Código da Unidade Gestora (UG) arrecadadora
SISGRU_UG=158461

# Intervalo de sincronização automática com o SISGRU (em minutos)
SISGRU_SYNC_INTERVAL_MINUTES=10

# =============================================================================
# pgAdmin (apenas desenvolvimento)
# =============================================================================

# E-mail de acesso ao pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@tesouraria.local

# Senha de acesso ao pgAdmin (obrigatório — defina antes de iniciar os containers)
PGADMIN_DEFAULT_PASSWORD=

# =============================================================================
# Aplicação
# =============================================================================

# Ambiente de execução: development | production
NODE_ENV=development

# Endereço de escuta do servidor Nuxt (0.0.0.0 para aceitar conexões externas no container)
NUXT_HOST=0.0.0.0

# Porta interna do servidor Nuxt
NUXT_PORT=3000
